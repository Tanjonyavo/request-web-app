# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database
# Use PostgreSQL by default for L3 compliance
DB_ENGINE=postgresql
POSTGRES_DB=uqo_requests
POSTGRES_USER=uqo_requests
POSTGRES_PASSWORD=uqo_requests
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Optional: provide DATABASE_URL instead of POSTGRES_* variables
# DATABASE_URL=postgresql://uqo_requests:uqo_requests@localhost:5432/uqo_requests
# DATABASE_URL=postgresql://uqo_requests:uqo_requests@localhost:5432/uqo_requests?sslmode=require

# Optional: tests fallback to SQLite
DJANGO_TEST_USE_SQLITE=True
